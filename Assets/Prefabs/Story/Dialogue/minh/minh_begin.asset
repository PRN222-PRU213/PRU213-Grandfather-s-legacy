%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0184bb0e6d60d664fb460ef3950717ee, type: 3}
  m_Name: minh_begin
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueID: minh_begin
  lines:
  - speakerName: Minh
    text: Hello, I am the manager of this archipelago.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: "I\u2019ll introduce you to the basics around here."
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: "On every island, you\u2019ll find a brown house and a dock."
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: The brown house is where you can sell fish for money.
    portrait: {fileID: 21300000, guid: 28651a35b01d90a4c9825ddfa518bd48, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: The dock lets you save your location and save time.
    portrait: {fileID: 21300000, guid: 497776c04cf899241a836065b2b3a850, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: "Out on the sea, you\u2019ll see swirling waters."
    portrait: {fileID: 21300000, guid: 74dba12255a95ca4ca2cdfa50df75b20, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Those are fishing spots.
    portrait: {fileID: 21300000, guid: 74dba12255a95ca4ca2cdfa50df75b20, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Each type of fish has a limited amount available each day.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: A new day will refresh the fish supply.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Some fish appear during the day, while others appear at night.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: "As for the rest, you\u2019ll have to discover it yourself."
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Since you are a stranger, if you want to stay here, you must prove yourself.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Walk around and take on tasks from the islanders to earn their trust.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: Oh, and remember to pay me for the boat you bought.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Minh
    text: The price is $2000.
    portrait: {fileID: 21300000, guid: fc8cf6c5533875a46ad8452f2f2db892, type: 3}
    setFlagAfter: 
    triggerQuestID: quest_1
    triggerID: notification_hide
