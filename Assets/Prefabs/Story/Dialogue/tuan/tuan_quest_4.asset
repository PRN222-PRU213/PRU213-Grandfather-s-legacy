  m_Script: {fileID: 11500000, guid: 0184bb0e6d60d664fb460ef3950717ee, type: 3}
  m_Name: tuan_quest_4
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueID: tuan_quest_4
  lines:
  - speakerName: Tuan
    text: Thank you.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Tuan
    text: Thanks to you, we now have enough food to survive.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Tuan
    text: "Since you helped us, I\u2019ll tell you a secret."
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Tuan
    text: "Behind this island, there\u2019s a very rare species of fish."
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
  - speakerName: Tuan
    text: If you have time, help me catch 2 of them.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: quest_5
