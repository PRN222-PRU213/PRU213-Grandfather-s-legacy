  dialogueID: tuan_begin
  lines:
  - speakerName: Tuan
    text: Minh sent you here?
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: It's always cold here.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: Because of that, resources are scarce.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: Please help me catch 9 cod.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
