  dialogueID: tuan_quest_5
  lines:
  - speakerName: Tuan
    text: "Wow, that\u2019s surprising."
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: "I didn\u2019t expect you to actually catch them."
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: Thank you.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: If you ever need help, just let me know.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: 
    triggerQuestID: 
    triggerID: 
  - speakerName: Tuan
    text: You should go see Minh.
    portrait: {fileID: 21300000, guid: 7a8ea276f119e07418af65523866f3d7, type: 3}
    setFlagAfter: tuan_finish
